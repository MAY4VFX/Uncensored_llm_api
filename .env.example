# Database
DATABASE_URL=postgresql+asyncpg://unchained:unchained@postgres:5432/unchained
DATABASE_URL_SYNC=postgresql://unchained:unchained@postgres:5432/unchained
POSTGRES_USER=unchained
POSTGRES_PASSWORD=unchained
POSTGRES_DB=unchained

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# RunPod
RUNPOD_API_KEY=your-runpod-api-key
RUNPOD_BASE_URL=https://api.runpod.ai/v2

# HuggingFace
HF_TOKEN=your-huggingface-token

# Paddle Billing
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
PADDLE_ENVIRONMENT=sandbox

# Scout Agent
SCOUT_INTERVAL_HOURS=2
SCOUT_AUTO_DEPLOY_MIN_DOWNLOADS=1000
SCOUT_AUTO_DEPLOY_MIN_LIKES=20
SCOUT_MIN_DOWNLOADS=100
SCOUT_MIN_LIKES=5

# Anthropic (for Scout LLM analysis)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
