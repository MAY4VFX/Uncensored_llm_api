# Backend Dokploy app
DATABASE_URL=postgresql+asyncpg://unchained:unchained@<postgres-host>:5432/unchained
DATABASE_URL_SYNC=postgresql://unchained:unchained@<postgres-host>:5432/unchained
REDIS_URL=redis://<redis-host>:6379/0
JWT_SECRET_KEY=<set-a-real-secret>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
RUNPOD_API_KEY=<runpod-api-key>
RUNPOD_BASE_URL=https://api.runpod.ai/v2
HF_TOKEN=<optional-hf-token>
PADDLE_API_KEY=<optional-paddle-api-key>
PADDLE_WEBHOOK_SECRET=<optional-paddle-webhook-secret>
PADDLE_ENVIRONMENT=sandbox
MODAL_TOKEN_ID=<modal-token-id>
MODAL_TOKEN_SECRET=<modal-token-secret>
MODAL_ENVIRONMENT=main
MODAL_APP_PREFIX=unchained
RUN_MIGRATIONS_ON_START=0
