# Scout Dokploy worker
DATABASE_URL_SYNC=postgresql://unchained:unchained@<postgres-host>:5432/unchained
RUNPOD_API_KEY=<runpod-api-key>
RUNPOD_BASE_URL=https://api.runpod.ai/v2
HF_TOKEN=<optional-hf-token>
ANTHROPIC_API_KEY=<anthropic-api-key>
SCOUT_INTERVAL_HOURS=2
SCOUT_AUTO_DEPLOY_MIN_DOWNLOADS=1000
SCOUT_AUTO_DEPLOY_MIN_LIKES=20
SCOUT_MIN_DOWNLOADS=100
SCOUT_MIN_LIKES=5
MODAL_TOKEN_ID=<modal-token-id>
MODAL_TOKEN_SECRET=<modal-token-secret>
MODAL_ENVIRONMENT=main
MODAL_APP_PREFIX=unchained
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
